{
  "name": "nucleon-cli",
  "version": "1.0.6",
  "description": "🚀 The Ultimate Developer Workflow Engine - One CLI to replace them all. Install globally: npm install -g nucleon-cli",
  "main": "dist/index.js",
  "bin": {
    "nucleon": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "start": "node dist/index.js",
    "postinstall": "node dist/postinstall.js || echo 'Setup will run on first use'",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "nucleon",
    "cli",
    "global-cli",
    "npm-install-g",
    "developer-tools",
    "workflow",
    "productivity",
    "automation",
    "project-init",
    "code-analysis",
    "deployment",
    "vercel",
    "git",
    "nextjs",
    "react",
    "typescript",
    "javascript",
    "python",
    "devops",
    "build-tools",
    "project-management",
    "developer-experience",
    "dx",
    "scaffolding",
    "boilerplate",
    "framework",
    "universal-cli",
    "dev-workflow",
    "project-health",
    "code-quality",
    "smart-commits",
    "task-management",
    "environment-setup",
    "global-installation"
  ],
  "author": {
    "name": "Naman Sharma",
    "email": "namansharma.web@gmail.com",
    "url": "https://github.com/namansharma28"
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/namansharma28/nucleon.git"
  },
  "bugs": {
    "url": "https://github.com/namansharma28/nucleon/issues"
  },
  "homepage": "https://github.com/namansharma28/nucleon#readme",
  "engines": {
    "node": ">=16.0.0",
    "npm": ">=7.0.0"
  },
  "os": [
    "darwin",
    "linux",
    "win32"
  ],
  "preferGlobal": true,
  "globalInstall": true,
  "files": [
    "dist/**/*",
    "README.md",
    "LICENSE",
    "CONTRIBUTING.md"
  ],
  "dependencies": {
    "commander": "^11.1.0",
    "chalk": "^4.1.2",
    "inquirer": "^8.2.6",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "@types/inquirer": "^8.2.10",
    "typescript": "^5.3.3"
  },
  "funding": {
    "type": "github",
    "url": "https://github.com/sponsors/namansharma28"
  },
  "maintainers": [
    {
      "name": "Naman Sharma",
      "email": "namansharma.web@gamil.com",
      "url": "https://github.com/namansharma28"
    }
  ],
  "contributors": [
    {
      "name": "Naman Sharma",
      "email": "namansharma.web@gamil.com",
      "url": "https://github.com/namansharma28"
    }
  ],
  "directories": {
    "lib": "./dist",
    "doc": "./README.md"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "installMessage": "Install globally: npm install -g nucleon-cli",
  "installation": {
    "command": "npm install -g nucleon-cli",
    "type": "global"
  }
}